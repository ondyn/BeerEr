rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // Helper functions
    // ---------------------------------------------------------------

    /// Returns true when the request comes from a signed-in user.
    function isSignedIn() {
      return request.auth != null;
    }

    /// Returns the uid of the authenticated user.
    function uid() {
      return request.auth.uid;
    }

    /// Reads the keg-session document for a given sessionId.
    function getSession(sessionId) {
      return get(/databases/$(database)/documents/kegSessions/$(sessionId));
    }

    /// Returns true when the authenticated user is a participant
    /// of the session identified by sessionId.
    function isParticipant(sessionId) {
      return uid() in getSession(sessionId).data.participant_ids;
    }

    /// Returns true when the authenticated user created the session.
    function isSessionCreator(sessionId) {
      return uid() == getSession(sessionId).data.creator_id;
    }

    // ---------------------------------------------------------------
    // users/{userId}
    //
    // • Any authenticated user can READ any profile (needed for
    //   participant lists, "pour for someone else", etc.).
    // • A user can only CREATE or UPDATE their own document.
    // • A user can only DELETE their own document.
    // ---------------------------------------------------------------
    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && uid() == userId;
      allow update: if isSignedIn() && uid() == userId;
      allow delete: if isSignedIn() && uid() == userId;
    }

    // ---------------------------------------------------------------
    // kegSessions/{sessionId}
    //
    // • Any authenticated user can GET a single session (needed for
    //   deep-link / QR-code join before the user is a participant).
    // • LIST is restricted to participants (queries filter by
    //   participant_ids arrayContains uid already, but we enforce it).
    // • CREATE: any authenticated user (becomes creator_id).
    //   – creator_id in the new document must equal the requester.
    // • UPDATE:
    //   – The creator can update any field.
    //   – Any authenticated user may add themselves to
    //     participant_ids (joining a session via deep link).
    // • DELETE: only the creator can delete a session.
    // ---------------------------------------------------------------
    match /kegSessions/{sessionId} {
      allow get:    if isSignedIn();

      allow list:   if isSignedIn()
                    && uid() in resource.data.participant_ids;

      allow create: if isSignedIn()
                    && request.resource.data.creator_id == uid();

      allow update: if isSignedIn()
                    && (
                      // The session creator can update anything.
                      resource.data.creator_id == uid()
                      ||
                      // A participant can update fields they need
                      // (e.g. volume_remaining_ml is updated via
                      //  transaction together with a pour).
                      uid() in resource.data.participant_ids
                      ||
                      // A new user joining — they add their own uid
                      // to participant_ids. We allow it as long as the
                      // user is authenticated (the addParticipant call).
                      (
                        uid() in request.resource.data.participant_ids
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['participant_ids'])
                      )
                    );

      allow delete: if isSignedIn()
                    && resource.data.creator_id == uid();
    }

    // ---------------------------------------------------------------
    // pours/{pourId}
    //
    // • READ: any session participant can read pours for that session.
    //   We verify the reader is a participant of the pour's session.
    // • CREATE: any authenticated session participant can log a pour.
    //   – poured_by_id must equal the requester (you can pour for
    //     someone else, but poured_by_id records who did it).
    //   – The pour's session must exist and the user must be a
    //     participant.
    // • UPDATE: only the user who poured (poured_by_id) or the
    //   session creator can undo a pour (set undone = true).
    //   No other field changes are allowed on update.
    // • DELETE: not allowed from clients — pours use soft-delete.
    // ---------------------------------------------------------------
    match /pours/{pourId} {
      allow read:   if isSignedIn()
                    && isParticipant(resource.data.session_id);

      allow create: if isSignedIn()
                    && request.resource.data.poured_by_id == uid()
                    && isParticipant(request.resource.data.session_id);

      allow update: if isSignedIn()
                    && (
                      resource.data.poured_by_id == uid()
                      || isSessionCreator(resource.data.session_id)
                    )
                    // Only the 'undone' field may change on an update.
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['undone']);

      allow delete: if false;
    }

    // ---------------------------------------------------------------
    // jointAccounts/{accountId}
    //
    // • READ: any participant of the associated session.
    // • CREATE: any participant of the session (they supply the
    //   session_id in the new document).
    // • UPDATE: any participant of the associated session
    //   (add/remove members, rename group).
    // • DELETE: only the session creator can remove a joint account.
    // ---------------------------------------------------------------
    match /jointAccounts/{accountId} {
      allow read:   if isSignedIn()
                    && isParticipant(resource.data.session_id);

      allow create: if isSignedIn()
                    && isParticipant(request.resource.data.session_id);

      allow update: if isSignedIn()
                    && isParticipant(resource.data.session_id);

      allow delete: if isSignedIn()
                    && isSessionCreator(resource.data.session_id);
    }

    // ---------------------------------------------------------------
    // Deny everything else by default.
    // No catch-all allow rule — unmatched paths are denied.
    // ---------------------------------------------------------------
  }
}

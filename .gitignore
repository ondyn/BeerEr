
# FVM — keep config, ignore the cached SDK symlink and downloaded versions
.fvm/flutter_sdk
.fvm/versions/

# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.metadata
build/
*.g.dart
*.freezed.dart
doc/api/

# Firebase generated — never commit these; each dev runs `flutterfire configure`
lib/firebase_options.dart
# Android Firebase config (contains API key)
google-services.json
**/google-services.json
# iOS Firebase config (contains API key)
GoogleService-Info.plist
**/GoogleService-Info.plist

# iOS
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/ServiceDefinitions.json

# Android
android/.gradle/
android/captures/
android/local.properties
android/key.properties
*.jks
*.keystore

# Cloud Functions — Node
functions/node_modules/
functions/lib/
functions/.env
functions/.env.*
functions/.secret.*

# Environment / secrets — general safety net
.env
.env.*
*.secret
*.pem
*.p12
*.pfx

# macOS
.DS_Store
**/.DS_Store

# IDE
.idea/
*.iml
.vscode/settings.json

# Misc
support

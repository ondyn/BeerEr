
# FVM — keep config, ignore the cached SDK symlink and downloaded versions
.fvm/flutter_sdk
.fvm/versions/

# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.metadata
build/
*.g.dart
*.freezed.dart
doc/api/

# Firebase generated — never commit these; each dev runs `flutterfire configure`
lib/firebase_options.dart
# Android Firebase config (contains API key)
google-services.json
**/google-services.json
# iOS Firebase config (contains API key)
GoogleService-Info.plist
**/GoogleService-Info.plist
# Firebase hosting cache
.firebase/

# iOS
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/ServiceDefinitions.json

# Android
android/.gradle/
android/captures/
android/local.properties
android/key.properties
*.jks
*.keystore
cmdline-tools/

# Cloud Functions — Node
functions/node_modules/
functions/lib/
functions/.env
functions/.env.*
functions/.secret.*

# Root-level Node.js (from scripts/firebase-admin usage)
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment / secrets — general safety net
.env
.env.*
*.secret
*.pem
*.p12
*.pfx
*service-account*.json
*firebase-adminsdk*.json
*sdk_key

# macOS
.DS_Store
**/.DS_Store

